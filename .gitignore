# Python
__pycache__/
*.pyc
*.egg-info/
.venv/
venv/

# SQLite store is local-only: it's a build artifact regenerable from refresh, and
# read_table() reads the .db before parquet — so a stale committed .db would shadow the
# fresh parquet on Streamlit Cloud. Ship parquet only; let the cloud use the parquet path.
*.db
*.db-wal
*.db-shm

# Tooling junk
.playwright-mcp/

# Data is public — the parquet snapshots in data/parquet/ are committed on purpose.
